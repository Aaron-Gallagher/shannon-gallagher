---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

export const personalProject = {
  title: 'LNER',
  description: 'Establishing intuitive and cohesive user experience through improved navigation and information structure.',
  tags: ['UX Research', 'Information Architecture', 'Product Design'],
  gradient: 'from-rose-600/20 to-red-500/20',
  accent: '#c8102e',
  featured: false,
  logo: '/logos/lner.svg',
  order: 2,
};
---

<Layout
  title="LNER Case Study — Shannon Gallagher"
  description="Establishing intuitive and cohesive user experience through improved navigation and information structure."
>
  <Nav />

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16">
      <div class="max-w-6xl mx-auto px-6">
        <a
          href="/"
          class="cs-back inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-10 opacity-0"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5M12 5l-7 7 7 7" />
          </svg>
          Back to work
        </a>

        <p class="cs-label text-sm font-semibold text-brand uppercase tracking-widest mb-5 opacity-0">LNER</p>

        <h1 class="cs-headline font-display text-4xl md:text-5xl lg:text-[3.5rem] font-bold text-gray-900 dark:text-white leading-tight max-w-4xl opacity-0">
          Establishing intuitive and cohesive user experience through improved navigation and information structure.
        </h1>
      </div>
    </section>

    <!-- Overview -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="border-t border-gray-100 dark:border-white/5 py-16">
        <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-3" data-animate>The Overview</p>
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed max-w-3xl" data-animate>
          The goal was to create a more intuitive and consistent interface that better supports users planning and managing train travel.
        </p>
      </div>
    </div>

    <!-- The Problem / LNER Website -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="border-t border-gray-100 dark:border-white/5 py-16">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
          <div data-animate>
            <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">The Problem</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
              The navigation system feels overwhelming causing key information to get lost within the clutter. The complex booking flow and unclear navigation makes it difficult for users to find journeys, compare fares, and complete ticket purchases smoothly.
            </p>
          </div>
          <div data-animate>
            <p class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-3">LNER website</p>
            <img
              src="/case-studies/lner/lner-website.png"
              alt="LNER website"
              class="w-full rounded-xl border border-gray-100 dark:border-white/10"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Current site / My Approach -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="border-t border-gray-100 dark:border-white/5 py-16">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
          <div data-animate>
            <img
              src="/case-studies/lner/lner-current.png"
              alt="Current LNER interface"
              class="w-full rounded-xl border border-gray-100 dark:border-white/10"
            />
          </div>
          <div class="md:pt-6" data-animate>
            <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">My Approach</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed mb-5">
              Through identifying pain points, I was able to focus on improving the booking journey, information architecture, and usability. Restructuring meant addressing usability issues by streamlining the journey search and ticket selection process.
            </p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
              I created custom assets and illustrations to help break up large sections of text and make information easier to scan. By introducing visual elements throughout the interface, users can process content in smaller, more digestible chunks.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-100 dark:bg-white/5" />
    </div>

    <!-- Experimentation -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="py-16">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
          <div data-animate>
            <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">Experimentation</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
              Simplified the landing page by removing the extra clutter.
            </p>
          </div>
          <div data-animate>
            <img
              src="/case-studies/lner/lner-experimentation.png"
              alt="Experimentation — redesigned landing page"
              class="w-full rounded-xl border border-gray-100 dark:border-white/10"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile / Repurposed -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="border-t border-gray-100 dark:border-white/5 py-16">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
          <div data-animate>
            <img
              src="/case-studies/lner/lner-mobile.png"
              alt="LNER mobile app design"
              class="w-full rounded-xl border border-gray-100 dark:border-white/10"
            />
          </div>
          <div data-animate>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
              Repurposed my original design of the landing page to promote LNER's app for users that need it on the go.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-100 dark:bg-white/5" />
    </div>

    <!-- My Solution -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="py-16">
        <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-12" data-animate>My Solution</p>
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
          <div data-animate>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
              I streamlined the booking journey to reduce friction, simplify decision-making, and help users complete ticket purchases more efficiently. My aim was to take large amounts of information spread across multiple sections and condense the most important content into one single place.
            </p>
          </div>
          <div data-animate>
            <img
              src="/case-studies/lner/lner-solution.png"
              alt="Solution — streamlined booking flow"
              class="w-full rounded-xl border border-gray-100 dark:border-white/10"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Booking / Streamlining -->
    <div class="max-w-6xl mx-auto px-6 pb-32">
      <div class="border-t border-gray-100 dark:border-white/5 py-16">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
          <div data-animate>
            <img
              src="/case-studies/lner/lner-booking.png"
              alt="Booking flow"
              class="w-full rounded-xl border border-gray-100 dark:border-white/10"
            />
          </div>
          <div data-animate>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
              Streamlining the booking process reduces cognitive load, allowing users to focus on choosing the best travel option rather than figuring out how to use the website.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Staggered hero entrance (runs after View Transition completes)
  function animateHero() {
    const items = [
      { sel: '.cs-back', delay: 100 },
      { sel: '.cs-label', delay: 250 },
      { sel: '.cs-headline', delay: 420 },
    ];

    items.forEach(({ sel, delay }) => {
      const el = document.querySelector(sel) as HTMLElement | null;
      if (!el) return;
      el.style.translate = '0 1.5rem';
      el.style.opacity = '0';
      setTimeout(() => {
        el.style.transition = 'opacity 0.7s cubic-bezier(0.22,1,0.36,1), translate 0.7s cubic-bezier(0.22,1,0.36,1)';
        el.style.translate = '0 0';
        el.style.opacity = '1';
      }, delay);
    });
  }

  // Fire on initial load and after each View Transition navigation
  animateHero();
  document.addEventListener('astro:page-load', animateHero);
</script>
