---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

export const personalProject = {
  title: 'Sony PlayStation',
  description: 'Digital e-commerce transformation — combining two separate platforms into a seamless, connected experience.',
  tags: ['UX Design', 'E-Commerce', 'Product Design'],
  gradient: 'from-blue-600/20 to-indigo-500/20',
  accent: '#003791',
  logo: '/logos/playstation.svg',
};

const imgPsLogo = "/personal-projects/playstation/ps-logo.png";
const imgBenchmarkOverview = "/personal-projects/playstation/benchmark-overview.png";
const imgConsoleBrowsing = "/personal-projects/playstation/solution-console-browsing.png";
const imgDesignView2 = "/personal-projects/playstation/solution-design-view-2.png";
const imgPaymentPage = "/personal-projects/playstation/solution-payment-page.png";
const imgBasketTop = "/personal-projects/playstation/solution-basket-top.png";
const imgBasketBottom = "/personal-projects/playstation/solution-basket-bottom.png";
---

<Layout
  title="Sony PlayStation — Shannon Gallagher"
  description="Digital e-commerce transformation — combining two separate platforms into a seamless, connected experience."
>
  <Nav />

  <main class="font-karla pt-[72px]">

    <!-- Hero -->
    <section
      class="relative min-h-[70vh] overflow-hidden flex flex-col"
      style="background-image: url('/personal-projects/playstation-hero-bg.png'); background-size: cover; background-position: center 30%;"
    >
      <!-- Back link -->
      <div class="relative z-10 max-w-6xl mx-auto px-6 pt-8 w-full">
        <a
          href="/"
          class="cs-back inline-flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors opacity-0"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5M12 5l-7 7 7 7" />
          </svg>
          Back to work
        </a>
      </div>

      <!-- Content — vertically centred in remaining space -->
      <div class="relative z-10 flex-1 flex items-center">
        <div class="max-w-6xl mx-auto px-6 w-full grid md:grid-cols-2 gap-12 items-center py-8">
          <!-- Left: logo → gap → headline + subtitle -->
          <div class="cs-label flex flex-col gap-20 opacity-0">
            <img
              src="/personal-projects/playstation/ps-logo-colour.png"
              alt="PlayStation"
              class="h-16 w-auto object-contain object-left"
            />
            <div class="flex flex-col gap-3">
              <h1 class="cs-headline font-karla text-[2.8rem] md:text-[3rem] font-normal leading-[1.15] text-white">
                One Console. Hundreds of Choices. One Clear Journey.
              </h1>
              <p class="cs-sub font-karla text-2xl font-light text-white/90 leading-[1.37]">
                Simplifying how users explore, customise and purchase PlayStation products.
              </p>
            </div>
          </div>

          <!-- Right: MacBook mockup -->
          <div class="cs-img opacity-0">
            <img
              src="/personal-projects/playstation/ps-hero-mockup.png"
              alt="PlayStation Store product page"
              class="w-full"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- The Challenge -->
    <div class="w-full overflow-hidden" data-animate>
      <img
        src="/personal-projects/playstation/challenge-background.png"
        alt="The challenge — combining two separate websites into a seamless connected experience"
        class="w-full object-cover"
      />
    </div>

    <!-- Site Audit -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
        <div>
          <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-2" data-animate>Site Audit</p>
          <p class="text-2xl font-medium text-gray-900 dark:text-white leading-[1.37] mb-6" data-animate>Understanding what currently exists</p>
          <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3" data-animate>Key findings</p>
          <ul class="space-y-2 text-base text-slate-600 dark:text-slate-400 leading-[1.37]" data-animate>
            <li>— PlayStation and PlayStation Store function as two separate platforms.</li>
            <li>— Disconnected experience from main site to ecommerce site</li>
            <li>— Basic e-commerce journey</li>
            <li>— Lacks opportunities to enhance the customer experience through additional items</li>
            <li>— Lack commercial opportunities to increase basket size through a guided e-commerce where customers can seamlessly purchase additional items</li>
          </ul>
        </div>
        <div class="space-y-4" data-animate>
          <img
            src="/personal-projects/playstation/ps-site-homepage.png"
            alt="Current PlayStation.com"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
          <img
            src="/personal-projects/playstation/ps-store-current.png"
            alt="Current PlayStation Store"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-200 dark:bg-white/5" />
    </div>

    <!-- Competitor Analysis -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-2" data-animate>Competitor Analysis</p>
      <p class="text-2xl font-medium text-gray-900 dark:text-white leading-[1.37] mb-2" data-animate>Key findings</p>
      <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-5" data-animate>Understand the competitive landscape</p>
      <ul class="grid md:grid-cols-2 gap-x-12 gap-y-2 text-base text-slate-600 dark:text-slate-400 leading-[1.37] mb-10" data-animate>
        <li>— One website for everything</li>
        <li>— Guided e-commerce journey</li>
        <li>— Seamless ability to purchase add ons</li>
        <li>— Easy navigation structures and pathways</li>
        <li>— Concise and informative resources</li>
        <li>— Distinct brand identities based on colour schemes, design language, typography and layout.</li>
      </ul>
      <div data-animate>
        <img
          src="/personal-projects/playstation/competitor-analysis-overview.png"
          alt="Competitor analysis overview — annotated FigJam board"
          class="w-full border border-gray-100 dark:border-white/10"
        />
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-200 dark:bg-white/5" />
    </div>

    <!-- Competitor Findings -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-2" data-animate>Competitor analysis findings</p>
      <p class="text-2xl font-medium text-gray-900 dark:text-white leading-[1.37] mb-12" data-animate>The detail</p>

      <!-- Meta Quest -->
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="space-y-6" data-animate>
          <div>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-1">Finding 1</p>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3">Meta Quest</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">High-quality product showcasing. Option to expand the storage size and add on any accessories before the payment method.</p>
          </div>
          <img
            src="/personal-projects/playstation/competitor-meta-quest-games.png"
            alt="Meta Quest — browse games before purchase"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
        </div>
        <div class="space-y-6" data-animate>
          <img
            src="/personal-projects/playstation/competitor-meta-quest-product.png"
            alt="Meta Quest product page — storage and accessory selection"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
          <div>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-1">Finding 2</p>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3">Meta Quest</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">Video advertising popular games. User is able to browse and add games before they commit to the payment.</p>
          </div>
        </div>
      </div>

      <!-- Nintendo -->
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="space-y-6" data-animate>
          <div>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-1">Finding 3</p>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3">Nintendo</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">Detailed information regarding the specifications of the Nintendo Switch. It doesn't include a price point in this section that's dedicated to Nintendo Switch.</p>
          </div>
          <img
            src="/personal-projects/playstation/competitor-nintendo-store.png"
            alt="My Nintendo Store purchase redirect"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
        </div>
        <div class="space-y-6" data-animate>
          <img
            src="/personal-projects/playstation/competitor-nintendo-specs.png"
            alt="Nintendo Switch specifications page"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
          <div>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-1">Finding 4</p>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3">Nintendo</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">In order to buy the product, you have to be redirected to My Nintendo Store. Opportunity to include Nintendo's accessories, such as cases, memory cards and controllers, underneath the option for purchase.</p>
          </div>
        </div>
      </div>

      <!-- Xbox -->
      <div class="grid md:grid-cols-2 gap-8">
        <div class="space-y-6" data-animate>
          <div>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-1">Finding 5</p>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3">Xbox</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">Detailed product showcase including multiple bundles and colour variants with clear pricing and a bundle gallery to guide purchasing decisions.</p>
          </div>
          <img
            src="/personal-projects/playstation/competitor-xbox-product.png"
            alt="Xbox Series S product page with bundle gallery"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
        </div>
        <div class="space-y-6" data-animate>
          <img
            src="/personal-projects/playstation/competitor-xbox-checkout.png"
            alt="Xbox checkout with people also buy"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
          <div>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-1">Finding 6</p>
            <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3">Xbox</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">In order to buy the product, you have to be redirected to a separate store. Opportunity to include accessories such as controllers and headsets underneath the option for purchase.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-200 dark:bg-white/5" />
    </div>

    <!-- Best Practice -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-2" data-animate>Best practice</p>
      <p class="text-2xl font-medium text-gray-900 dark:text-white leading-[1.37] mb-2" data-animate>Benchmarking Apple, Google, Amazon, ASOS…</p>
      <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-4" data-animate>Industry leading</p>
      <ul class="space-y-2 text-base text-slate-600 dark:text-slate-400 leading-[1.37] mb-10 max-w-2xl" data-animate>
        <li>— Interactive design elements elevate user experience by immersing them into the product.</li>
        <li>— E-Commerce efficiency - easy to navigate through detailed product information and specifications that allow users to make an informed decision.</li>
        <li>— Rich media and multimedia integration allow for a dynamic and visually appealing product display.</li>
        <li>— Visual hierarchy - effectively guides user's attention and prioritises relevant content.</li>
      </ul>
      <div data-animate>
        <img
          src={imgBenchmarkOverview}
          alt="Best practice benchmarking — Apple, ASOS, Amazon, Google"
          class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
        />
      </div>
    </div>

    <!-- Design Working Out -->
    <div class="max-w-6xl mx-auto px-6 pb-16">
      <p class="text-2xl font-medium text-gray-900 dark:text-white leading-[1.37] mb-8" data-animate>Design working out</p>
      <div data-animate>
        <img
          src="/personal-projects/playstation/wireframes.jpg"
          alt="Design working out — wireframe sketches"
          class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
        />
      </div>
    </div>

    <!-- The Solution — full-width with text + mockup overlay -->
    <div
      class="relative w-full py-20 px-6 text-center"
      style="background-image: url('/personal-projects/playstation/solution-statement.png'); background-size: cover; background-position: center;"
      data-animate
    >
      <p class="text-2xl md:text-[2rem] font-semibold text-white mb-4">The solution</p>
      <p class="text-xl md:text-[2.5rem] font-normal text-white leading-[1.37] max-w-3xl mx-auto mb-10">
        How did I answer the challenge?
      </p>
      <div class="max-w-2xl mx-auto">
        <img
          src="/personal-projects/playstation/solution-mockups.png"
          alt="PlayStation redesign — full solution overview"
          class="w-full"
        />
      </div>
    </div>

    <!-- My Solution — new design screenshots -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="font-sans text-base text-gray-900 dark:text-white mb-6" data-animate>
        My design of the PlayStation console browsing page
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="space-y-8" data-animate>
          <img
            src={imgConsoleBrowsing}
            alt="PlayStation console browsing page design"
            class="w-full rounded-[5px] border border-[#ececec] dark:border-white/10"
          />
          <div>
            <p class="text-base font-medium text-gray-900 dark:text-white leading-[1.37] mb-3">Accessory Customisation</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">Including extra straight after the product, creates a more seamless purchasing journey, adding compatible products at the point of selection rather than navigating through multiple pages. This aimed to simplify bundle creation and improve product discoverability.</p>
          </div>
        </div>
        <div class="space-y-8" data-animate>
          <div>
            <p class="text-base font-medium text-gray-900 dark:text-white leading-[1.37] mb-3">My Approach</p>
            <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">Through identifying pain points, i was able to develop a concept solution focused on improving the booking journey, information architecture, and usability. Restructuring meant addressing usability issues by streamlining the journey search and ticket selection process and improving information hierarchy,</p>
          </div>
          <img
            src={imgDesignView2}
            alt="PlayStation redesign — game selection view"
            class="w-full rounded-[5px] border border-[#ececec] dark:border-white/10"
          />
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-200 dark:bg-white/5" />
    </div>

    <!-- Payment Process -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-base font-medium text-gray-900 dark:text-white leading-[1.37] mb-8" data-animate>Payment Process</p>

      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start mb-16">
        <div data-animate>
          <img
            src={imgPaymentPage}
            alt="Payment page design"
            class="w-full rounded-[5px] border border-[#ececec] dark:border-white/10"
          />
        </div>
        <div data-animate>
          <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37] mb-2">My Solution</p>
          <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">A seamless flow where users can go through the purchasing process without feeling any uncertainty. The consistency in layout, language, and design patterns reinforces the idea that the platform is reliable and secure.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div class="rounded-[5px] overflow-hidden border border-[#ececec] dark:border-white/10" data-animate>
          <img src={imgBasketTop} alt="PlayStation basket design" class="w-full" />
          <img src={imgBasketBottom} alt="PlayStation checkout design" class="w-full" />
        </div>
        <div class="self-end" data-animate>
          <p class="text-base text-slate-600 dark:text-slate-400 leading-[1.37]">With the payment process it's important for it to feel reliable, user-friendly, and thoughtfully designed. This encourages users to return and continue engaging with the service.</p>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <hr class="border-none h-px bg-gray-200 dark:bg-white/5" />
    </div>

    <!-- User Testing -->
    <div class="max-w-6xl mx-auto px-6 py-16 pb-32">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
        <div>
          <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-2" data-animate>User testing</p>
          <p class="text-2xl font-medium text-gray-900 dark:text-white leading-[1.37] mb-6" data-animate>Validating the designs with users</p>
          <p class="text-base text-[#766767] dark:text-slate-500 leading-[1.37] mb-3" data-animate>What I would of done</p>
          <ul class="space-y-2 text-base text-slate-600 dark:text-slate-400 leading-[1.37]" data-animate>
            <li>— Formulate a discussion guide</li>
            <li>— Testing designs on regular users of PS products</li>
            <li>— Take note of participant's feedback</li>
            <li>— Amend designs based on feedback</li>
          </ul>
        </div>
        <div data-animate>
          <img
            src="/personal-projects/playstation/user-testing.jpg"
            alt="User testing session"
            class="w-full rounded-[5px] border border-gray-100 dark:border-white/10"
          />
        </div>
      </div>
    </div>

  </main>
</Layout>

<script>
  function animateHero() {
    const items = [
      { sel: '.cs-back', delay: 100 },
      { sel: '.cs-label', delay: 250 },
      { sel: '.cs-img', delay: 400 },
    ];

    items.forEach(({ sel, delay }) => {
      const el = document.querySelector(sel) as HTMLElement | null;
      if (!el) return;
      el.style.translate = '0 1.5rem';
      el.style.opacity = '0';
      setTimeout(() => {
        el.style.transition = 'opacity 0.7s cubic-bezier(0.22,1,0.36,1), translate 0.7s cubic-bezier(0.22,1,0.36,1)';
        el.style.translate = '0 0';
        el.style.opacity = '1';
      }, delay);
    });
  }

  animateHero();
  document.addEventListener('astro:page-load', animateHero);
</script>
