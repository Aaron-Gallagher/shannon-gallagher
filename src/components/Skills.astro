---
const categories = [
  {
    name: 'Frontend',
    icon: '⬡',
    skills: [
      { name: 'React / Next.js', level: 92 },
      { name: 'Astro', level: 88 },
      { name: 'TypeScript', level: 85 },
      { name: 'TailwindCSS', level: 95 },
      { name: 'Framer Motion', level: 78 },
    ],
  },
  {
    name: 'Backend',
    icon: '◈',
    skills: [
      { name: 'Node.js / Express', level: 88 },
      { name: 'Go', level: 72 },
      { name: 'PostgreSQL', level: 82 },
      { name: 'Redis', level: 75 },
      { name: 'REST & GraphQL', level: 85 },
    ],
  },
  {
    name: 'Tooling & Cloud',
    icon: '◎',
    skills: [
      { name: 'Docker', level: 78 },
      { name: 'GitHub Actions', level: 82 },
      { name: 'Vercel / Cloudflare', level: 90 },
      { name: 'Supabase / Firebase', level: 85 },
      { name: 'AWS (S3, Lambda)', level: 68 },
    ],
  },
];
---

<section id="skills" class="py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 space-y-4">
      <p class="text-brand text-sm font-medium tracking-widest uppercase" data-animate>What I know</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-gray-900 dark:text-white" data-animate>
        Skills &amp; <em class="not-italic gradient-text">Tools</em>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {categories.map((cat) => (
        <div class="bg-surface-3 rounded-2xl p-6 border border-gray-100 dark:border-white/5" data-animate>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl text-brand">{cat.icon}</span>
            <h3 class="text-gray-900 dark:text-white font-semibold text-lg">{cat.name}</h3>
          </div>
          <ul class="space-y-4">
            {cat.skills.map((skill) => (
              <li>
                <div class="flex justify-between text-sm mb-1.5">
                  <span class="text-slate-700 dark:text-slate-300">{skill.name}</span>
                  <span class="text-slate-500">{skill.level}%</span>
                </div>
                <div class="h-1.5 bg-gray-200 dark:bg-white/5 rounded-full overflow-hidden">
                  <div
                    class="skill-bar h-full rounded-full bg-gradient-to-r from-brand-dark to-brand-light"
                    style={`--target: ${skill.level}%; width: 0%`}
                  ></div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Animate skill bars when section enters view
  const skillBars = document.querySelectorAll<HTMLElement>('.skill-bar');

  const barObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const bar = entry.target as HTMLElement;
          const target = bar.style.getPropertyValue('--target');
          bar.style.transition = 'width 1s cubic-bezier(0.22,1,0.36,1)';
          bar.style.width = target;
          barObserver.unobserve(bar);
        }
      });
    },
    { threshold: 0.3 }
  );

  skillBars.forEach((bar) => barObserver.observe(bar));
</script>
