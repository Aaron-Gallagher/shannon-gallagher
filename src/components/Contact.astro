  {
    name: 'GitHub',
    href: 'https://github.com',
    icon: `<path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>`,
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    name: 'Twitter / X',
    href: 'https://x.com',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
];
---

<section id="contact" class="py-32 px-6 bg-surface-2 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-dark/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-3xl mx-auto relative z-10">
    <div class="text-center mb-12 space-y-4">
      <p class="text-brand text-sm font-medium tracking-widest uppercase" data-animate>Get in touch</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white" data-animate>
        Let's build something <em class="not-italic gradient-text">together</em>
      </h2>
      <p class="text-slate-400 max-w-md mx-auto" data-animate>
        Whether you have a project in mind or just want to say hi, my inbox is always open.
      </p>
    </div>

    <form
      class="bg-surface-3 rounded-3xl p-8 md:p-10 border border-white/5 space-y-6 shadow-2xl"
      data-animate
      action="#"
      method="POST"
    >
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label for="name" class="text-sm text-slate-400">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="Shannon"
            class="w-full bg-surface-2 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-all"
          />
        </div>
        <div class="space-y-2">
          <label for="email" class="text-sm text-slate-400">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="shannon@example.com"
            class="w-full bg-surface-2 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-all"
          />
        </div>
      </div>

      <div class="space-y-2">
        <label for="subject" class="text-sm text-slate-400">Subject</label>
        <input
          id="subject"
          name="subject"
          type="text"
          placeholder="Project enquiry"
          class="w-full bg-surface-2 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-all"
        />
      </div>

      <div class="space-y-2">
        <label for="message" class="text-sm text-slate-400">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          placeholder="Tell me about your project..."
          class="w-full bg-surface-2 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand/50 focus:ring-1 focus:ring-brand/30 transition-all resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-3.5 rounded-xl bg-brand text-white font-medium hover:bg-brand-light transition-all duration-300 hover:shadow-[0_0_30px_rgba(167,139,250,0.4)] active:scale-[0.98]"
      >
        Send message
      </button>
    </form>

    <!-- Socials -->
    <div class="flex items-center justify-center gap-6 mt-12" data-animate>
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.name}
          class="w-10 h-10 rounded-full bg-surface-3 border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:border-brand/40 transition-all duration-300 hover:scale-110"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon} />
        </a>
      ))}
    </div>

    <p class="text-center text-slate-600 text-sm mt-8" data-animate>
      © {new Date().getFullYear()} Shannon Gallagher. Built with Astro &amp; TailwindCSS.
    </p>
  </div>
</section>
