---
---

<section id="about" class="py-32">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <!-- Image / graphic -->
    <div class="relative" data-animate>
      <div class="aspect-square max-w-sm mx-auto relative">
        <!-- Placeholder avatar with gradient -->
        <div class="w-full h-full rounded-3xl bg-gradient-to-br from-brand-dark/40 via-surface-3 to-pink-900/30 border border-gray-100 dark:border-white/5 flex items-center justify-center overflow-hidden">
          <svg class="w-40 h-40 text-brand/20" viewBox="0 0 100 100" fill="currentColor">
            <circle cx="50" cy="38" r="20"/>
            <ellipse cx="50" cy="80" rx="32" ry="22"/>
          </svg>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -right-4 bg-surface-3 border border-gray-100 dark:border-white/10 rounded-2xl px-5 py-3 shadow-xl">
          <p class="text-2xl font-bold text-gray-900 dark:text-white">3+</p>
          <p class="text-xs text-slate-500 dark:text-slate-400">Years exp.</p>
        </div>
        <!-- Decoration ring -->
        <div class="absolute -inset-4 rounded-3xl border border-brand/10 pointer-events-none"></div>
      </div>
    </div>

    <!-- Text -->
    <div class="space-y-6">
      <p class="text-brand text-sm font-medium tracking-widest uppercase" data-animate>About me</p>

      <h2 class="font-display text-4xl md:text-5xl font-bold text-gray-900 dark:text-white leading-tight" data-animate>
        Turning ideas into <em class="not-italic gradient-text">real products</em>
      </h2>

      <p class="text-slate-600 dark:text-slate-400 leading-relaxed" data-animate>
        I'm a full-stack developer based in Ireland with a passion for clean design,
        fast code, and accessible experiences. I love working across the entire stack —
        from pixel-perfect UIs to rock-solid APIs.
      </p>

      <p class="text-slate-600 dark:text-slate-400 leading-relaxed" data-animate>
        When I'm not coding you'll find me hiking, reading, or experimenting with
        new design tools. I'm currently open to freelance projects and full-time
        opportunities.
      </p>

      <div class="grid grid-cols-2 gap-4 pt-2" data-animate>
        {[
          ['Location', 'Dublin, Ireland'],
          ['Availability', 'Open to work'],
          ['Focus', 'Web & Mobile'],
          ['Education', 'BSc Computer Science'],
        ].map(([label, value]) => (
          <div class="bg-surface-3 rounded-xl p-4 border border-gray-100 dark:border-white/5">
            <p class="text-xs text-slate-500 mb-1">{label}</p>
            <p class="text-sm text-gray-900 dark:text-white font-medium">{value}</p>
          </div>
        ))}
      </div>

      <div class="flex gap-4 pt-2" data-animate>
        <a
          href="/resume.pdf"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-surface-3 border border-gray-200 dark:border-white/10 text-sm text-slate-700 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white hover:border-brand/40 transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
          </svg>
          Download CV
        </a>
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-surface-3 border border-gray-200 dark:border-white/10 text-sm text-slate-700 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white hover:border-brand/40 transition-all duration-300"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>
