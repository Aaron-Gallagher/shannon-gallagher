---
---

<section id="about" class="py-32">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <!-- Image / graphic -->
    <div class="relative" data-animate>
      <div class="max-w-sm mx-auto relative">
        <!-- Card frame -->
        <div class="rounded-3xl border border-gray-100 dark:border-white/5 overflow-hidden" style="height: 480px;">
          <img
            src="/IMG_3550.jpg"
            alt="Shannon Gallagher"
            class="w-full h-full object-cover object-top"
          />
        </div>
        <!-- Decoration ring -->
        <div class="absolute -inset-4 rounded-3xl border border-brand/10 pointer-events-none"></div>
      </div>
    </div>

    <!-- Text -->
    <div class="space-y-6">
      <p class="text-brand text-sm font-medium tracking-widest uppercase" data-animate>About me</p>

      <h2 class="font-display text-4xl md:text-5xl font-bold text-gray-900 dark:text-white leading-tight" data-animate>
        Turning ideas into <em class="not-italic gradient-text">real products</em>
      </h2>

      <p class="text-slate-600 dark:text-slate-400 leading-relaxed" data-animate>
        Junior Product Designer with experience supporting the design of
        customer-facing digital products within the financial services sector.
      </p>

      <p class="text-slate-600 dark:text-slate-400 leading-relaxed" data-animate>
        Passionate about creating simple and intuitive experiences that help
        customers achieve their goals.
      </p>

      <p class="text-slate-600 dark:text-slate-400 leading-relaxed" data-animate>
        Experience supporting design activities including research, wireframing,
        prototyping and feedback sessions.
      </p>

      <div class="flex gap-4 pt-2" data-animate>
        <a
          href="/Shannon%20Gallagher%20-%20Junior%20Product%20Designer%20CV%202026.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-surface-3 border border-gray-200 dark:border-white/10 text-sm text-slate-700 dark:text-slate-300 hover:text-gray-900 dark:hover:text-white hover:border-brand/40 transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
          </svg>
          Download CV
        </a>
      </div>
    </div>
  </div>
</section>
