---
const projects = [
  {
    title: 'Yoclo',
    description: 'A social platform connecting creators with their audience. Built with Next.js, Supabase, and Stripe for subscriptions.',
    tags: ['Next.js', 'Supabase', 'Stripe', 'TypeScript'],
    href: '#',
    gradient: 'from-violet-600/20 to-pink-600/20',
    accent: '#a78bfa',
    featured: true,
  },
  {
    title: 'Health Dashboard',
    description: 'Real-time health metrics dashboard with beautiful charts, goal tracking, and personalised insights.',
    tags: ['React', 'D3.js', 'Node.js', 'PostgreSQL'],
    href: '#',
    gradient: 'from-cyan-600/20 to-blue-600/20',
    accent: '#67e8f9',
    featured: false,
  },
  {
    title: 'Quiz Master',
    description: 'Multiplayer quiz game with live lobbies, custom quiz creation, and a global leaderboard.',
    tags: ['Astro', 'WebSockets', 'Redis', 'TailwindCSS'],
    href: '#',
    gradient: 'from-amber-600/20 to-orange-600/20',
    accent: '#fbbf24',
    featured: false,
  },
  {
    title: 'Geo Page Studio',
    description: 'No-code landing page builder with geolocation-aware content blocks for local businesses.',
    tags: ['Vue 3', 'Express', 'MongoDB', 'Mapbox'],
    href: '#',
    gradient: 'from-emerald-600/20 to-teal-600/20',
    accent: '#34d399',
    featured: false,
  },
  {
    title: 'Dev Notes',
    description: 'A markdown-first developer note-taking API with tag search, code blocks, and CLI sync.',
    tags: ['Go', 'REST API', 'SQLite', 'JWT'],
    href: '#',
    gradient: 'from-rose-600/20 to-red-600/20',
    accent: '#fb7185',
    featured: false,
  },
];
---

<section id="projects" class="py-32 px-6 bg-surface-2">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 space-y-4">
      <p class="text-brand text-sm font-medium tracking-widest uppercase" data-animate>My work</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white" data-animate>
        Selected <em class="not-italic gradient-text">Projects</em>
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto" data-animate>
        A handful of things I've built. Every project is a chance to learn something new.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a
          href={project.href}
          class={`glow-card group relative bg-surface-3 rounded-2xl p-6 border border-white/5 flex flex-col gap-4 ${project.featured ? 'md:col-span-2 lg:col-span-1' : ''}`}
          data-animate
        >
          <!-- Top gradient bar -->
          <div class={`absolute top-0 inset-x-0 h-px bg-gradient-to-r ${project.gradient} rounded-t-2xl`}></div>

          <!-- Icon placeholder -->
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center"
            style={`background: ${project.accent}18; border: 1px solid ${project.accent}30`}
          >
            <div class="w-3 h-3 rounded-full" style={`background: ${project.accent}`}></div>
          </div>

          <div class="flex-1">
            <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-brand transition-colors">
              {project.title}
            </h3>
            <p class="text-slate-400 text-sm leading-relaxed">{project.description}</p>
          </div>

          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-white/5 text-slate-400 border border-white/5">
                {tag}
              </span>
            ))}
          </div>

          <!-- Arrow -->
          <div class="absolute bottom-5 right-5 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-1 group-hover:translate-x-0">
            <svg class="w-4 h-4 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
