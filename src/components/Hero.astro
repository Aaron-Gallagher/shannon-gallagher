---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6 pt-20">
  <!-- Animated grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(167,139,250,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(167,139,250,0.04)_1px,transparent_1px)] bg-[size:60px_60px]" aria-hidden="true"></div>

  <!-- Radial glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-dark/20 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <p class="hero-tag inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-brand/30 bg-brand/5 text-brand text-sm mb-8 opacity-0">
      <span class="w-2 h-2 rounded-full bg-brand animate-pulse"></span>
      Junior Product Designer
    </p>

    <h1 class="hero-title font-display text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white leading-[1.05] mb-6 opacity-0">
      Hi, I'm <em class="not-italic gradient-text">Shannon</em><br />
      I'm a Junior Product Designer<br />
      focused on user-centred experiences.
    </h1>

    <p class="hero-sub max-w-xl mx-auto text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-10 opacity-0">
      I combine research, strategy, and problem-solving to create meaningful user experiences.
    </p>

    <div class="hero-ctas flex items-center justify-center opacity-0">
      <a
        href="#case-studies"
        class="px-7 py-3.5 rounded-full bg-brand text-white font-medium hover:bg-brand-light transition-all duration-300 hover:shadow-[0_0_30px_rgba(167,139,250,0.4)] active:scale-95"
      >
        See my work
      </a>
    </div>
  </div>
</section>

<script>
  function animateHero() {
    // Reset state before animating (handles re-entry via View Transitions)
    document.querySelectorAll<HTMLElement>('.hero-tag,.hero-title,.hero-sub,.hero-ctas').forEach(el => {
      el.style.transition = 'none';
      el.style.opacity = '0';
      el.style.translate = '0 1.5rem';
    });

    const items = [
      { sel: '.hero-tag', delay: 200 },
      { sel: '.hero-title', delay: 400 },
      { sel: '.hero-sub', delay: 600 },
      { sel: '.hero-ctas', delay: 800 },
    ];

    items.forEach(({ sel, delay }) => {
      const el = document.querySelector(sel) as HTMLElement | null;
      if (!el) return;
      setTimeout(() => {
        el.style.transition = 'opacity 0.7s cubic-bezier(0.22,1,0.36,1), translate 0.7s cubic-bezier(0.22,1,0.36,1)';
        el.style.translate = '0 0';
        el.style.opacity = '1';
      }, delay);
    });
  }

  animateHero();
  document.addEventListener('astro:page-load', animateHero);
</script>
